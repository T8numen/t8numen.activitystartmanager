<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="bottom"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/home_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/version_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end|bottom"
            android:textSize="12sp" />

        <Button
            android:id="@+id/more_button"
            android:layout_width="64dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text="@string/more_actions" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/old_module_warning_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#FFFFE0B2"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/old_module_warning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/old_module_warning"
            android:textColor="#FF5D4037"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/old_module_warning_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="@string/close_warning"
            android:textColor="#FF5D4037"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/rule_help_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#FFF5F5F5"
        android:padding="10dp"
        android:text="@string/rule_help_text"
        android:textIsSelectable="true"
        android:textSize="12sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/rule_summary_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#FFEFF3F8"
        android:padding="8dp"
        android:textColor="#FF455A64"
        android:textIsSelectable="true"
        android:textSize="12sp" />

    <HorizontalScrollView
        android:id="@+id/rule_editor_horizontal_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:fadeScrollbars="false"
        android:fillViewport="false"
        android:scrollbars="horizontal">

        <t8numen.activitystartmanager.RuleEditText
            android:id="@+id/rule_editor"
            android:layout_width="1200dp"
            android:layout_height="match_parent"
            android:gravity="top|start"
            android:inputType="textMultiLine|textNoSuggestions"
            android:minHeight="320dp"
            android:padding="12dp"
            android:scrollHorizontally="true"
            android:scrollbars="vertical"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:typeface="monospace" />
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/save_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/save_rules" />

        <Button
            android:id="@+id/check_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/check_rules" />
    </LinearLayout>

    <TextView
        android:id="@+id/rule_check_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#FF555555"
        android:textIsSelectable="true"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/recent_records_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#FFF5F5F5"
        android:padding="10dp"
        android:textColor="#FF444444"
        android:textIsSelectable="true"
        android:textSize="12sp"
        android:visibility="gone" />
</LinearLayout>
